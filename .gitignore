# Unity project is under DragonKnight/ subdirectory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/
DragonKnight/[Ll]ibrary/
DragonKnight/[Tt]emp/
DragonKnight/[Oo]bj/
DragonKnight/[Bb]uild/
DragonKnight/[Bb]uilds/
DragonKnight/[Ll]ogs/
DragonKnight/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
DragonKnight/[Mm]emoryCaptures/

# Recordings can get excessive in size
DragonKnight/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# DragonKnight/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
DragonKnight/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
DragonKnight/ServerData
DragonKnight/[Aa]ssets/StreamingAssets/aa*
DragonKnight/[Aa]ssets/AddressableAssetsData/link.xml*
DragonKnight/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
DragonKnight/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
DragonKnight/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
DragonKnight/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
DragonKnight/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
DragonKnight/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
DragonKnight/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# VSCode workspace settings
DragonKnight/.vscode/
